# =================================
# EkanshGPT Backend Configuration
# =================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── ChromaDB Cloud ────────────────────────────────────
# Get these from your ChromaDB Cloud dashboard
CHROMA_API_KEY=your-chroma-api-key-here
CHROMA_TENANT=your-tenant-id-here
CHROMA_DATABASE=your-database-name-here
CHROMA_COLLECTION_NAME=ekanshgpt_documents

# ── HuggingFace ───────────────────────────────────────
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=your-huggingface-token-here

# ── Embedding Model ──────────────────────────────────
# Runs locally via sentence-transformers (free, no API calls)
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# ── Server ────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Upload directory for temporary file storage ──────
UPLOAD_DIR=./uploads

# ── Chunking defaults ────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Document owner (for metadata) ────────────────────
DOCUMENT_OWNER=ekansh
